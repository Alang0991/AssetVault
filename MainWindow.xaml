<Window x:Class="AssetVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AssetVault"
        Width="1500"
        Height="920"
        MinWidth="1200"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">

    <Grid Background="{StaticResource WindowBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SecondaryPanelBg}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,1,0"
                Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="AssetVault"
                               FontSize="28"
                               FontWeight="Bold"
                               Margin="0,0,0,6" />
                    <TextBlock Text="VRChat &amp; Unity Asset Manager"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               Margin="0,0,0,24" />

                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Click="DashboardButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Library" Click="LibraryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Import Assets" Click="ImportButton_Click" />

                    <TextBlock Text="Categories"
                               Margin="8,26,0,10"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               FontWeight="SemiBold" />

                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Avatars" Tag="Avatars" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Clothing" Tag="Clothing" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Accessories" Tag="Accessories" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Hair" Tag="Hair" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Props" Tag="Props" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="World Assets" Tag="World Assets" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Textures" Tag="Textures" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Shaders" Tag="Shaders" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Animations" Tag="Animations" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Audio" Tag="Audio" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="Unity Packages" Tag="Unity Packages" Click="CategoryButton_Click" />
                    <Button Style="{StaticResource SidebarButtonStyle}" Content="NSFW" Tag="NSFW" Click="CategoryButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="80" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{StaticResource WindowBg}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1"
                    Padding="28,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="PageTitleText"
                               Text="Dashboard"
                               VerticalAlignment="Center"
                               FontSize="26"
                               FontWeight="Bold" />

                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Height="42"
                             VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged" />
                </Grid>
            </Border>

            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="Transparent" />
        </Grid>
    </Grid>
</Window>