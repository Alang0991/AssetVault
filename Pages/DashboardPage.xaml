<Page x:Class="AssetVault.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Dashboard">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28">
            <TextBlock Text="Overview"
                       FontSize="30"
                       FontWeight="Bold"
                       Margin="0,0,0,24" />

            <WrapPanel Margin="0,0,0,18">
                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total Assets"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="TotalAssetsText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Clothing"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="ClothingAssetsText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Accessories"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="AccessoriesAssetsText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Hair"
                                   FontSize="14"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                        <TextBlock x:Name="HairAssetsText"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Margin="0,12,0,0" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Recently Imported"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,16" />

                    <ItemsControl x:Name="RecentAssetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource SecondaryPanelBg}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Padding="14"
                                        Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="16"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Tags}"
                                                       Margin="0,5,0,0"
                                                       Foreground="{StaticResource SecondaryTextBrush}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Category}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DateAdded}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{StaticResource SecondaryTextBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>