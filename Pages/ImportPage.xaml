<Page x:Class="AssetVault.Pages.ImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Import">

    <Grid Margin="28">

        <Grid.RowDefinitions>
            <RowDefinition Height="300"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- DRAG & DROP -->

        <Border Grid.Row="0"
                Background="{StaticResource PanelBg}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="18"
                AllowDrop="True"
                Drop="DropZone_Drop"
                DragOver="DropZone_DragOver">

            <Grid>

                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock Text="Drag &amp; Drop Assets Here"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Import VRChat, Unity, image, audio, and package files"
                               Margin="0,10,0,20"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">

                        <Button Content="Choose Files"
                                Width="150"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ChooseFilesButton_Click"/>

                        <Button Content="Scan Folder"
                                Width="150"
                                Margin="10,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="ScanFolderButton_Click"/>

                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>



        <!-- SCAN STATUS -->

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="4,0,0,8">

            <TextBlock Text="Scanning Status:"
                       FontWeight="SemiBold"
                       Margin="0,0,12,0"/>

            <TextBlock x:Name="ScanTimerText"
                       Text="Elapsed: 00:00"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Margin="0,0,20,0"/>

            <TextBlock x:Name="FileCountText"
                       Text="Files Found: 0"
                       Foreground="{StaticResource SecondaryTextBrush}"/>

        </StackPanel>



        <!-- IMPORT PROGRESS -->

        <StackPanel Grid.Row="3"
                    Margin="0,0,0,10">

            <TextBlock Text="Import Progress"
                       FontWeight="SemiBold"
                       Margin="0,0,0,6"/>

            <ProgressBar x:Name="ImportProgressBar"
                         Height="12"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Margin="0,0,0,6"/>

            <TextBlock x:Name="ImportStatusText"
                       Text="Waiting for import..."
                       Foreground="{StaticResource SecondaryTextBrush}"/>

        </StackPanel>



        <!-- PENDING FILES -->

        <Border Grid.Row="4"
                Style="{StaticResource CardBorderStyle}">

            <StackPanel>

                <TextBlock Text="Pending Files"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,14"/>

                <ListBox x:Name="PendingFilesListBox"
                         Height="260"
                         VirtualizingStackPanel.IsVirtualizing="True"
                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                         ScrollViewer.CanContentScroll="True"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>

                    <ListBox.ItemTemplate>

                        <DataTemplate>

                            <Grid Margin="0,2">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <!-- FILE NAME -->

                                <TextBlock Text="{Binding}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- REMOVE BUTTON -->

                                <Button Grid.Column="1"
                                        Content="✕"
                                        Width="26"
                                        Height="22"
                                        Tag="{Binding}"
                                        Click="RemovePendingFile_Click"
                                        Background="#E74C3C"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontWeight="Bold"/>

                            </Grid>

                        </DataTemplate>

                    </ListBox.ItemTemplate>

                </ListBox>

            </StackPanel>

        </Border>



        <!-- BUTTONS -->

        <StackPanel Grid.Row="6"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Clear"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ClearButton_Click"/>

            <Button Content="Import"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ImportButton_Click"/>

        </StackPanel>

    </Grid>

</Page>